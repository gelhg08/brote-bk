{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(npm test -- *)",
      "Bash(npx prisma *)",
      "Bash(npx nest *)",
      "Bash(npx jest *)",
      "Bash(npx vitest *)",
      "Bash(npx ts-node *)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git switch *)",
      "Bash(git checkout *)",
      "Bash(git restore *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git push)",
      "Bash(git push origin *)",
      "Bash(git stash *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr create *)",
      "Bash(gh pr checks *)",
      "Bash(gh repo view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f)",
      "Bash(git push --force-with-lease*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Read(./.env)",
      "Read(.env)",
      "Read(./.env.local)",
      "Read(./.env.development)",
      "Read(./.env.test)",
      "Read(./.env.production)",
      "Read(./.env.*.local)",
      "WebFetch(domain:production.wompi.co)"
    ],
    "ask": [
      "Bash(aws *)",
      "Bash(git push --tags*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-tool-guard.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/stop-lint-test.mjs\"",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
