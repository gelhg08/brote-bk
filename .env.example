# ─────────────────────────────────────────────────────────────────────────────
# Brote Backend — variables de entorno (PLANTILLA)
# Copia este archivo a `.env` y rellena valores. NUNCA pongas secretos reales aquí.
# `.env` está en .gitignore; este `.env.example` SÍ se versiona (sin secretos).
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
# Origen del frontend permitido por CORS (sin barra final)
FRONTEND_ORIGIN=http://localhost:3001

# ── Base de datos (MySQL) ────────────────────────────────────────────────────
# Usuario con permisos de la app (lectura/escritura).
DATABASE_URL="mysql://brote_app:CAMBIA_ESTO@localhost:3306/brote"
# Usuario de SOLO LECTURA para el MCP de inspección de esquema (GRANT SELECT).
# Lo usa .mcp.json (servidor mysql-readonly). Distinto del de la app.
DATABASE_URL_READONLY="mysql://brote_readonly:CAMBIA_ESTO@localhost:3306/brote"

# ── Wompi (SOLO SANDBOX en desarrollo) ───────────────────────────────────────
# Prefijos test_/pub_test_ obligatorios en local. El hook de seguridad BLOQUEA
# cualquier llave/URL de producción (pub_prod_, prv_prod_, prod_*, production.wompi.co).
WOMPI_BASE_URL=https://sandbox.wompi.co/v1
WOMPI_PUBLIC_KEY=pub_test_XXXXXXXXXXXXXXXXXXXX        # se expone al frontend
WOMPI_PRIVATE_KEY=prv_test_XXXXXXXXXXXXXXXXXXXX       # SOLO servidor
WOMPI_INTEGRITY_SECRET=test_integrity_XXXXXXXXXXXX    # SOLO servidor (firma de integridad)
WOMPI_EVENTS_SECRET=test_events_XXXXXXXXXXXXXXXX      # SOLO servidor (verificación de webhook)

# Ventana anti-replay para webhooks (segundos)
WOMPI_WEBHOOK_TOLERANCE_SECONDS=300
